  "keyFeatures": [
    "Descriptor-aware selectors with automatic persistence for deterministic replay",
    "Unified API for local and cloud browser automation execution",
    "Structured data extraction with typed schemas",
    "Computer Use Agent (CUA) support for autonomous workflows",
    "Built-in HTML cleaning and snapshot optimization",
    "CLI and SDK interfaces for flexible integration"
  ],
