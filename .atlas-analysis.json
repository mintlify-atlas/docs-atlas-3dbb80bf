    "snapshot() / extract() / extractFromPlan() extraction methods",
    "agent() / agent.execute() CUA methods",
    "uploadFile() / screenshot() / state() utility methods",
    "getTabs() / getTab() / switchTab() / openTab() / closeTab() tab management",
    "exportCookies() / importCookies() cookie management",
